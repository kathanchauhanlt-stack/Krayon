# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ── Firebase Configuration ───────────────────────────────────────────────────
# Copy these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_APP_ID"
# Optional: Only needed if Firebase Analytics is enabled
VITE_FIREBASE_MEASUREMENT_ID=""

# Firebase Realtime Database URL (required for Light Novel → Comic pipeline)
# Enable Realtime Database in Firebase Console: Build → Realtime Database → Create Database
VITE_FIREBASE_DATABASE_URL="https://MY_PROJECT_ID-default-rtdb.firebaseio.com"

# ── API Configuration ────────────────────────────────────────────────────────
# Base URL for the Express backend. Leave empty for local dev (uses localhost:3001)
VITE_API_URL=""
